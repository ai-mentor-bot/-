# まず一式確認: npm run verify（.env 経路・キー・Supabase 疎通、課金なし）
# コピーして .env として保存 → npm run test:smoke（DBだけ）/ npm run daily（本番に近い）
# または クロードコードまとめ/.env にまとめて置いても可（load-env.mjs が親フォルダを辿って読み込みます）
# SUPABASE_KEY は原則 service_role（RLS バイパス・upsert 確実）。anon の場合は SQL で UPDATE ポリシー必須。
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
LINE_MESSAGING_API_TOKEN=
LINE_USER_ID=
# 任意（未設定時は朝KPIリマインドの定型文）
# LINE_PUSH_TEXT=
# Gmail SMTP（アプリパスワード）— 日次・月次の通知をメールでも送る（例は架空。実メールは .env にのみ）
GMAIL_USER=your-email@example.com
GMAIL_APP_PASSWORD=
# 省略時は GMAIL_USER 宛。アプリパスワードは 16 文字（コピー時のスペースは自動除去）
NOTIFY_EMAIL_TO=your-email@example.com
# 任意（未設定時は package.json のデフォルト相当）
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_ENABLE_THINKING=0
# GitHub 定時を有効にする前: ローカルで npm run test:email を成功させたあと
# Repo → Settings → Variables and secrets → Variables → CURATOR_CRON_ENABLED = true
